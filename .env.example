# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartphones
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STREAM=smartphones_raw
REDIS_FAILED_STREAM=smartphones_failed

# === Mercado Livre API ===
ML_API_BASE_URL=https://api.mercadolibre.com
ML_SITE_ID=MLB
ML_CATEGORY_ID=MLB1055
ML_SEARCH_LIMIT=50
ML_MAX_PAGES=10

# === Prefect ===
PREFECT_API_URL=http://localhost:4200/api

# === Collector ===
COLLECTOR_BATCH_SIZE=50
COLLECTOR_SLEEP_BETWEEN_PAGES=2

# === Dashboard ===
STREAMLIT_PORT=8501