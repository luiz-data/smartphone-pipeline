# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartphones
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STREAM=smartphones_raw
REDIS_FAILED_STREAM=smartphones_failed

# === Amazon BR via RapidAPI ===
# 1. Crie conta gratuita em https://rapidapi.com
# 2. Assine: Real-Time Amazon Data
# 3. Copie sua X-RapidAPI-Key
RAPIDAPI_KEY=
RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com
AMAZON_DOMAIN=www.amazon.com.br
AMAZON_SEARCH_QUERY=smartphone
AMAZON_MAX_PAGES=10
AMAZON_PAGE_SIZE=48

# === Prefect ===
PREFECT_API_URL=http://prefect-server:4200/api

# === Collector ===
COLLECTOR_BATCH_SIZE=50
COLLECTOR_SLEEP_BETWEEN_PAGES=2

# === Dashboard ===
STREAMLIT_PORT=8501